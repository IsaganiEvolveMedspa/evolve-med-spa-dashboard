# Backend environment variables — set these in the Railway service (Variables tab).
# Do NOT commit real values. This file is just a template.

DB_USER=your_sql_user
DB_PASSWORD=your_sql_password
DB_SERVER=your-server.database.windows.net   # host or IP of the SQL Server
DB_NAME=your_database
DB_PORT=1433

DB_ENCRYPT=true            # true for Azure SQL
DB_TRUST_CERT=false        # true only if using a self-signed cert

# Lock CORS to your dashboard URL in production:
ALLOWED_ORIGIN=*

# Payroll estimate: no hourly-rate column exists in EMPLOYEE_SCHEDULES, so the
# finance payroll calc uses this blended hourly rate * 1.12 (12% add-on per KPI def).
# Set to your real blended rate. Default in code is 45.
BLENDED_HOURLY_RATE=45

# PORT is provided automatically by Railway.
