# === SQL Server (main data) ===
SQL_SERVER_HOST=your-sql-server.database.windows.net
SQL_SERVER_PORT=1433
SQL_SERVER_USER=your_user
SQL_SERVER_PASSWORD=your_password
SQL_SERVER_DATABASE=your_database

# Table names (without dbo. prefix — config.py adds it via defaults if needed)
SQL_SALES_TABLE=BRONZE_ZENOTI_SALES_ACCRUAL
SQL_APPT_TABLE=BRONZE_ZENOTI_APPOINTMENTS
SQL_SCHEDULE_TABLE=BRONZE_ZENOTI_EMPLOYEE_SCHEDULES
SQL_CASH_TABLE=BRONZE_ZENOTI_CASH_COLLECTIONS

# === BigQuery (logging + AI insights cache only) ===
BIGQUERY_CREDENTIALS_BASE64=your_base64_encoded_service_account_json
BIGQUERY_PROJECT_ID=your-project-id
BIGQUERY_DATASET=your_dataset
BIGQUERY_API_LOG_TABLE=api_log
BIGQUERY_INSIGHTS_TABLE=ai_insights_log

# === AI Insights (optional) ===
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
